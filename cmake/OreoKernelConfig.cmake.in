@PACKAGE_INIT@

# OreoKernelConfig.cmake — generated by configure_package_config_file()
#
# Downstream usage:
#   find_package(OreoKernel CONFIG REQUIRED)
#   target_link_libraries(myapp PRIVATE OreoKernel::oreo-kernel)
#
# OreoKernel's PUBLIC link interface depends on OpenCASCADE, Boost,
# Eigen, Qt6 Core, and nlohmann_json. We re-resolve them here so the
# imported target carries through correctly.

include(CMakeFindDependencyMacro)

find_dependency(OpenCASCADE   CONFIG)
find_dependency(Boost         COMPONENTS graph iostreams)
find_dependency(Eigen3        CONFIG)
find_dependency(Qt6           COMPONENTS Core)
find_dependency(nlohmann_json CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/OreoKernelTargets.cmake")

check_required_components(OreoKernel)
